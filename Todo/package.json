{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "简洁优雅的桌面待办事项管理应用",
  "main": "main.js",
  "author": "Todo App",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.todo.desktop",
    "productName": "Todo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "manifest.json",
      "sw.js",
      "icon-192.svg",
      "icon-512.svg"
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "signAndEditExecutable": false,
      "signDlls": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Todo"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/ios": "^8.3.4"
  }
}
